  "item": [
    {
      "name": "Get All Pets",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// pm.response is the response object",
              "// and the method json deserializes the response",
              "// from a json string to a javascript data structure",
              "const pets = pm.response.json();",
              "",
              "// pm.test - create a test with a human-readable label",
              "// + a function that runs the actual test",
              "",
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "",
              "pm.test('Response is an array', () => pm.expect(pets).to.be.an('array'));",
              "",
              "pm.test('The cat Moshi must exist in the DB', () => {",
              "    let found = pets.find(pet => pet.name === 'Moshi' && pet.species === 'cat' );",
              "    pm.expect(found).to.exist;",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5001/api/pets",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5001",
          "path": [
            "api",
            "pets"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Pets",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Read dummy data for pets have previously created",
              "// in the pre-request script for the whole collection",
              "const pets = pm.variables.get('pets');",
              "",
              "// Get current counter value (used to decide which dummy data item to use)",
              "const getCounter = eval(pm.variables.get('getCounter'));",
              "const counter = getCounter();",
              "",
              "// Set petName and petSpecies as collectionVariables",
              "// so that the request body inclusions with {{petName}} etc will work",
              "pm.variables.set('petName', pets[counter].name);",
              "pm.variables.set('petSpecies', pets[counter].species);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Read pets and counter from pm.variables",
              "const pets = pm.variables.get('pets');",
              "const counter = pm.variables.get('counter');",
              "",
              "// pm.response is the response object",
              "// and the method json deserializes the response",
              "// from a json string to a javascript data structure",
              "const messageOnPost = pm.response.json();",
              "",
              "// pm.test - create a test with a human-readable label",
              "// + a function that runs the actual test",
              "",
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "",
              "pm.test('The response should inlcude changes = 1', () => ",
              "    pm.expect(messageOnPost.changes).to.equal(1)",
              ");",
              "",
              "let insertRowId = messageOnPost.lastInsertRowid;",
              "",
              "pm.test('The response should include insertRowId as number',() => ",
              "    pm.expect(insertRowId).to.be.a('number')",
              ");",
              "",
              "// Add the (insert) id to the dummy data",
              "pets[counter].id = insertRowId;",
              "pm.variables.set('pets', pets);",
              "",
              "// Loop this request if we haven't gone through all dummy data",
              "const loop = eval(pm.variables.get('loop'));",
              "loop('pets');",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"{{petName}}\",\n    \"species\": \"{{petSpecies}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:5001/api/pets",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5001",
          "path": [
            "api",
            "pets"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Read Pets",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Read dummy data for pets have previously created",
              "// in the pre-request script for the whole collection",
              "const pets = pm.variables.get('pets');",
              "",
              "// Get current counter value (used to decide which dummy data item to use)",
              "const getCounter = eval(pm.variables.get('getCounter'));",
              "const counter = getCounter();",
              "",
              "// Set petId (used in the route url)",
              "pm.variables.set('petId', pets[counter].id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Read pets and counter from pm.variables",
              "const pets = pm.variables.get('pets');",
              "const counter = pm.variables.get('counter');",
              "",
              "// pm.response is the response object",
              "// and the method json deserializes the response",
              "// from a json string to a javascript data structure",
              "const petFromDb = pm.response.json();",
              "",
              "// pm.test - create a test with a human-readable label",
              "// + a function that runs the actual test",
              "",
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "",
              "// check that was is stored in the db equals the dummy data",
              "// but add userId: null to dummy data before check because",
              "// this exists in the db, make a deep equal comparison",
              "",
              "pm.test('Db data equals earlier written dummy data', () => ",
              "    pm.expect(petFromDb).to.deep.equal({...pets[counter], userId: null})",
              ");",
              "",
              "// Loop this request if we haven't gone through all dummy data",
              "const loop = eval(pm.variables.get('loop'));",
              "loop('pets');",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": ""
        },
        "url": {
          "raw": "http://localhost:5001/api/pets/{{petId}}",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5001",
          "path": [
            "api",
            "pets",
            "{{petId}}"
          ]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Set dummy data ",
          "",
          "pm.variables.get('pets') || pm.variables.set('pets',[",
          "  {",
          "    \"name\": \"Whiskers\",",
          "    \"species\": \"cat\"",
          "  },",
          "  {",
          "    \"name\": \"Bubbles\",",
          "    \"species\": \"goldfish\"",
          "  },",
          "  {",
          "    \"name\": \"Thumper\",",
          "    \"species\": \"rabbit\"",
          "  },",
          "  {",
          "    \"name\": \"Polly\",",
          "    \"species\": \"parrot\"",
          "  },",
          "  {",
          "    \"name\": \"Spike\",",
          "    \"species\": \"hedgehog\"",
          "  }",
          "]);",
          "",
          "// Helper functions",
          "",
          "// getCounter - helper function to be called first in",
          "// a pre-request script to get the counter value ",
          "pm.variables.set('getCounter', (() => {",
          "    pm.variables.get('counter') === undefined && pm.variables.set('counter',0);",
          "    return pm.variables.get('counter');",
          "}).toString());",
          "",
          "// loop - helper function to be called last in",
          "// a post-response script to loop the request",
          "pm.variables.set('loop', ((dummyDataKey) => {",
          "    // check if we have gone trough all dummy data",
          "    let counter = pm.variables.get('counter');",
          "    let dummyDataArray = pm.variables.get(dummyDataKey);",
          "    if(counter < dummyDataArray.length - 1){",
          "        // Incree the counter and call the current request again",
          "        pm.variables.set('counter', counter + 1);",
          "        pm.execution.setNextRequest(pm.info.requestName);",
          "    }",
          "    else {",
          "        // Unset the counter (so it can be reused)",
          "        pm.variables.unset('counter');",
          "    }",
          "}).toString());",
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    }
  ]
