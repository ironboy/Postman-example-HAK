{
  "info": {
    "_postman_id": "bb65bbc5-34a0-48ef-b70c-981453c40e40",
    "name": "PetTest",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "30881265"
  },
  "item": [
    {
      "name": "Get All Pets",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// pm.response is the response object",
              "// and the method json deserializes the response",
              "// from a json string to a javascript data structure",
              "const pets = pm.response.json();",
              "",
              "// pm.test - create a test with a human-readable label",
              "// + a function that runs the actual test",
              "",
              "pm.test('Status code is 200', () => pm.response.to.have.status(200));",
              "",
              "pm.test('Response is an array', () => pm.expect(pets).to.be.an('array'));",
              "",
              "pm.test('The cat Moshi must exist in the DB', () => {",
              "    let found = pets.find(pet => pet.name === 'Moshi' && pet.species === 'cat' );",
              "    pm.expect(found).to.exist;",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5001/api/pets",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5001",
          "path": [
            "api",
            "pets"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Create Pets",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Read dummy data fort pets have previously created",
              "// in the pre-request script for the whole collection",
              "const pets = pm.variables.get('pets');",
              "",
              "// Set a counter for which pet we are about to create",
              "// if the counter doesn't exist already",
              "pm.variables.get('counter') === undefined && pm.variables.set('counter', 0);",
              "",
              "// Read the counter to a local variable ",
              "const counter = pm.variables.get('counter');",
              "",
              "// Set petName and petSpecies as collectionVariables",
              "// so that the request body inclusions with {{petName}} etc will work",
              "pm.variables.set('petName', pets[counter].name);",
              "pm.variables.set('petSpecies', pets[counter].species);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Test",
              "",
              "",
              "// Check if we should loop (if there are more pets to add)",
              "const pets = pm.variables.get('pets');",
              "const counter = pm.variables.get('counter');",
              "",
              "// Loop by increeing the counter and repeating",
              "// this request if there are more pets to create",
              "if(counter < pets.length - 1){",
              "    pm.variables.set('counter', counter + 1);",
              "    pm.execution.setNextRequest('Create Pets');",
              "}",
              "else {",
              "    // Reset remove counter so that we later can use similar",
              "    // logic with a conuter variable in other requests",
              "    pm.variables.delete('counter');",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"{{petName}}\",\n    \"species\": \"{{petSpecies}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:5001/api/pets",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "5001",
          "path": [
            "api",
            "pets"
          ]
        }
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
