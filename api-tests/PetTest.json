        "exec": [
          "pm.variables.set('pets',[",
          "  {",
          "    \"name\": \"Whiskers\",",
          "    \"species\": \"cat\"",
          "  },",
          "  {",
          "    \"name\": \"Bubbles\",",
          "    \"species\": \"goldfish\"",
          "  },",
          "  {",
          "    \"name\": \"Thumper\",",
          "    \"species\": \"rabbit\"",
          "  },",
          "  {",
          "    \"name\": \"Polly\",",
          "    \"species\": \"parrot\"",
          "  },",
          "  {",
          "    \"name\": \"Spike\",",
          "    \"species\": \"hedgehog\"",
          "  }",
          "]);"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    }
  ]
